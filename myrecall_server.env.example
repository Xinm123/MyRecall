# OpenRecall Server Configuration Template
# Copy this file to myrecall_server.env and fill in your values

# ==============================================================================
# AI Provider Configuration (Global)
# ==============================================================================
# Use 'openai' for OpenAI-compatible APIs (OpenAI, DeepSeek, vLLM, etc.)
# Use 'dashscope' for Aliyun DashScope
OPENRECALL_AI_PROVIDER=openai

# Timeout for AI provider requests in seconds (Default: 120)
OPENRECALL_AI_REQUEST_TIMEOUT=120

# API Key (Required) - REPLACE WITH YOUR ACTUAL KEY
OPENRECALL_AI_API_KEY=your-api-key-here

# Base URL (Optional, for proxies or alternative providers)
# OPENRECALL_AI_API_BASE=https://api.example.com/v1/

# ==============================================================================
# Description Generation (Frame AI Analysis)
# ==============================================================================
# Enable/disable description generation (default: true)
OPENRECALL_DESCRIPTION_ENABLED=true

# Provider: local | openai | dashscope
OPENRECALL_DESCRIPTION_PROVIDER=openai

# Model name for description
# For local vLLM: Qwen3-VL-8B-Instruct (matches --model arg)
# For cloud: e.g., Qwen/Qwen3-VL-32B-Instruct
OPENRECALL_DESCRIPTION_MODEL=Qwen3-VL-8B-Instruct

# API Key for description model (leave empty for local vLLM without auth)
OPENRECALL_DESCRIPTION_API_KEY=EMPTY

# API Base URL for description model service
# For local vLLM: http://127.0.0.1:8090/v1
# For cloud proxy: https://api.example.com/v1/
OPENRECALL_DESCRIPTION_API_BASE=http://127.0.0.1:8090/v1

# ==============================================================================
# Vision Language Model (VL) Settings
# ==============================================================================
# Falls back to OPENRECALL_AI_PROVIDER if not set
OPENRECALL_VISION_PROVIDER=openai

# Model Name (e.g., gpt-4o, gpt-4o-mini, qwen-vl-max)
OPENRECALL_VISION_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct

# ==============================================================================
# Embedding Model Settings
# ==============================================================================
# Falls back to OPENRECALL_AI_PROVIDER if not set
OPENRECALL_EMBEDDING_PROVIDER=openai

# Model Name (e.g., text-embedding-3-small, text-embedding-v3)
OPENRECALL_EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B

# Embedding Dimension (Must match the model output)
OPENRECALL_EMBEDDING_DIM=1024

# ==============================================================================
# OCR Settings
# ==============================================================================
OPENRECALL_OCR_PROVIDER=rapidocr

# OCR Model Version: PP-OCRv4 (default, bundled with pip) or PP-OCRv5 (requires first-use download)
# PP-OCRv4 is recommended for most use cases - no network dependency after pip install
# OPENRECALL_OCR_RAPID_OCR_VERSION=PP-OCRv4

# Model Type: mobile (fast, lightweight) or server (accurate, heavier)
# OPENRECALL_OCR_RAPID_MODEL_TYPE=mobile

# OCR Quality Tuning Parameters (optional, see PaddleOCR docs for details)
# OPENRECALL_OCR_DET_LIMIT_SIDE_LEN=960
# OPENRECALL_OCR_DET_DB_THRESH=0.3
# OPENRECALL_OCR_DET_DB_BOX_THRESH=0.7
# OPENRECALL_OCR_DET_DB_UNCLIP_RATIO=1.6
# OPENRECALL_OCR_DROP_SCORE=0.6

OPENRECALL_PRELOAD_MODELS=true

# ==============================================================================
# System Settings
# ==============================================================================
OPENRECALL_PORT=8083
OPENRECALL_DEBUG=true

# Only capture the primary monitor (set to false to capture all monitors)
OPENRECALL_PRIMARY_MONITOR_ONLY=true

# Disable similarity-based deduplication (set to true to capture every cycle)
OPENRECALL_DISABLE_SIMILARITY_FILTER=false

# Similarity threshold (0.0-1.0)
OPENRECALL_SIMILARITY_THRESHOLD=0.9

# ==============================================================================
# Data Directory Settings
# ==============================================================================
# Server Data Directory (Default: ~/MRS)
OPENRECALL_SERVER_DATA_DIR=~/MRS
# Client Data Directory (Default: ~/MRC)
OPENRECALL_CLIENT_DATA_DIR=~/MRC

# ==============================================================================
# Reranker Settings
# ==============================================================================
# Mode: 'api' (default, requires external service) or 'local' (runs in-process)
OPENRECALL_RERANKER_MODE=api
# Model Name
OPENRECALL_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
# API URL for reranker service
# For local vLLM reranker: http://127.0.0.1:8080/rerank
# For cloud: https://api.example.com/v1/rerank
OPENRECALL_RERANKER_URL=http://127.0.0.1:8080/rerank
# API Key for reranker (leave empty for local reranker without auth)
OPENRECALL_RERANKER_API_KEY=EMPTY

# ==============================================================================
# Debugging & Logging
# ==============================================================================
OPENRECALL_FUSION_LOG_ENABLED=true
