# OpenRecall Client Configuration

# ==============================================================================
# Connection Settings
# ==============================================================================
# The URL of the OpenRecall server API
# Ensure the port matches OPENRECALL_PORT in the server config (default 18083)
OPENRECALL_API_URL=http://localhost:8083/api

# Upload timeout in seconds (increase if server is slow processing)
OPENRECALL_UPLOAD_TIMEOUT=180

# ==============================================================================
# Capture Settings
# ==============================================================================
# Screenshot capture interval in seconds
OPENRECALL_CAPTURE_INTERVAL=30

# Minimum debounce interval between captures (ms)
OPENRECALL_MIN_CAPTURE_INTERVAL_MS=3000

OPENRECALL_IDLE_CAPTURE_INTERVAL_MS=60000
# Only capture the primary monitor (set to false to capture all monitors)
OPENRECALL_PRIMARY_MONITOR_ONLY=false

# Disable similarity-based deduplication (set to true to capture every cycle)
OPENRECALL_DISABLE_SIMILARITY_FILTER=false

# Similarity threshold (0.0-1.0). Higher values capture more (images considered similar when score >= threshold)
OPENRECALL_SIMILARITY_THRESHOLD=0.9

# ==============================================================================
# P1-S2b+ Simhash Dedup Configuration
# ==============================================================================
# Enable PHash-based similarity deduplication (drop near-duplicate frames)
OPENRECALL_SIMHASH_DEDUP_ENABLED=true

# Hamming distance threshold for similarity (<= threshold is considered similar)
OPENRECALL_SIMHASH_DEDUP_THRESHOLD=8

# Number of recent hashes cached per monitor/device
OPENRECALL_SIMHASH_CACHE_SIZE=1

# Per-trigger-type simhash enablement (IDLE always skips simhash)
OPENRECALL_SIMHASH_ENABLED_FOR_CLICK=true
OPENRECALL_SIMHASH_ENABLED_FOR_APP_SWITCH=true

# ==============================================================================
# Debug & Storage
# ==============================================================================
# Enable debug logging
OPENRECALL_DEBUG=true

# Save screenshots locally on the client as well (useful for debugging or backup)
# OPENRECALL_CLIENT_SAVE_LOCAL_SCREENSHOTS=false
