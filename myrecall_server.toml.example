# OpenRecall Server Configuration Template
# Copy this file to ~/.myrecall/server.toml or ./server.toml and fill in your values
# Or use: openrecall-server --config /path/to/server.toml

# ==============================================================================
# Server Settings
# ==============================================================================
[server]
host = "0.0.0.0"
port = 8083
debug = false

# ==============================================================================
# Path Settings
# ==============================================================================
[paths]
data_dir = "~/.myrecall/server"
cache_dir = "~/.myrecall/cache"

# ==============================================================================
# AI Provider (Global fallback for vision, embedding, description)
# ==============================================================================
[ai]
provider = "local"           # Options: local, openai, dashscope
device = "cpu"               # Options: cpu, cuda, mps
model_name = ""              # Model name (e.g., Qwen3-VL-8B-Instruct)
api_key = ""                 # API key if required
api_base = ""                # Base URL for API (e.g., http://localhost:8080/v1)
request_timeout = 120        # Timeout for AI provider requests (seconds)

# ==============================================================================
# OCR Settings
# ==============================================================================
[ocr]
provider = "rapidocr"        # Options: rapidocr
model_name = ""              # OCR model name (empty = bundled default)
rapid_version = "PP-OCRv4"   # Options: PP-OCRv4, PP-OCRv5
model_type = "mobile"        # Options: mobile, server

# ==============================================================================
# Description Generation (Frame AI Analysis)
# ==============================================================================
# IMPORTANT: [description] section is INDEPENDENT from [ai] section.
# No fallback to [ai] - you MUST configure [description] explicitly.
#
# To use the same provider as [ai], copy the values from [ai] to [description].
# Example:
#   [ai]
#   provider = "openai"
#   api_key = "sk-..."
#
#   [description]
#   provider = "openai"      # Must set explicitly
#   api_key = "sk-..."       # Must set explicitly
#
# To disable description generation, set enabled = false
# ==============================================================================
[description]
enabled = true                      # Enable description generation
provider = "local"                  # Options: local, openai, dashscope
model = ""                          # Model name (e.g., Qwen3-VL-8B-Instruct)
api_key = ""                        # API key if required
api_base = ""                       # Base URL (e.g., http://127.0.0.1:8090/v1)

# ==============================================================================
# Embedding Settings (Multimodal Vector Search)
# ==============================================================================
# IMPORTANT: [embedding] section is INDEPENDENT from [ai] section.
# Configure explicitly for embedding generation.
#
# Provider Options:
#   - "multimodal": Custom qwen3-vl-embedding API (true image+text fusion)
#   - "openai": OpenAI text-embedding API (text only, no image support)
#   - "dashscope": DashScope native API (implementation pending)
#
# Example - Custom multimodal API (qwen3-vl-embedding):
#   [embedding]
#   enabled = true
#   provider = "multimodal"
#   model = "qwen3-vl-embedding"
#   api_base = "http://localhost:8070/v1"
#   dim = 1024
#
# Example - DashScope OpenAI-compatible mode:
#   [embedding]
#   enabled = true
#   provider = "openai"
#   model = "text-embedding-v3"
#   api_key = "sk-..."
#   api_base = "https://dashscope.aliyuncs.com/compatible-mode/v1"
#
# Example - OpenAI official:
#   [embedding]
#   enabled = true
#   provider = "openai"
#   model = "text-embedding-3-small"
#   api_key = "sk-..."
# ==============================================================================
[embedding]
enabled = true                      # Enable embedding generation
provider = "openai"                 # Options: multimodal, openai, dashscope
model = "qwen3-vl-embedding"        # Embedding model name
api_key = ""                        # API key if required
api_base = ""                       # API base URL (e.g., http://localhost:8070/v1)
dim = 1024                          # Embedding dimension (for multimodal provider)

# ==============================================================================
# Reranker Settings
# ==============================================================================
[reranker]
enabled = false                     # Enable reranking
mode = "api"                         # Options: api, local
url = "http://localhost:8083/rerank" # Reranker API URL
model = "Qwen/Qwen3-Reranker-0.6B"   # Model name
api_key = ""                         # API key if required

# ==============================================================================
# Processing Settings
# ==============================================================================
[processing]
mode = "ocr"                  # Processing mode: ocr
queue_capacity = 200          # Queue capacity
preload_models = true         # Preload models at startup

# ==============================================================================
# UI Settings
# ==============================================================================
[ui]
show_ai_description = true   # Show AI description in UI

# ==============================================================================
# Advanced Settings
# ==============================================================================
[advanced]
fusion_log_enabled = false    # Enable fusion debug logging
