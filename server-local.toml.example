# OpenRecall Server Configuration — Local Mode (Template)
#
# Copy this file to `server-local.toml` and fill in your own values.
# `server-local.toml` is gitignored to avoid committing secrets.
#
# Server listens on localhost only (127.0.0.1) when host is set as below.

# ==============================================================================
# Server Settings
# ==============================================================================
[server]
host = "127.0.0.1"   # Localhost only — not accessible from other machines
port = 8083
debug = true

# ==============================================================================
# Path Settings
# ==============================================================================
[paths]
data_dir = "~/.myrecall/server"
cache_dir = "~/.myrecall/cache"

# ==============================================================================
# AI Provider (Global fallback for vision, embedding, description)
# ==============================================================================
[ai]
provider = "openai"
device = "cpu"
model_name = ""
api_key = ""
api_base = ""
request_timeout = 120

# ==============================================================================
# OCR Settings
# ==============================================================================
[ocr]
provider = "rapidocr"
model_name = ""
rapid_version = "PP-OCRv4"
model_type = "mobile"

# ==============================================================================
# Description Generation (Frame AI Analysis)
# ==============================================================================
# Pick ONE of the variants below and uncomment it.
# Keep `api_key` blank in committed templates — fill it in your own copy only.
[description]
enabled = true
provider = "openai"
model = "Qwen/Qwen3-VL-8B-Instruct"
api_key = ""                                  # e.g. "sk-..." (your own key)
api_base = "https://api.siliconflow.cn/v1/"

# Alternate: self-hosted Qwen3-VL endpoint
#enabled = true
#provider = "openai"
#model = "Qwen3-VL-8B-Instruct"
#api_key = "EMPTY"
#api_base = "http://localhost:8090/v1/"

# ==============================================================================
# Embedding Settings
# ==============================================================================
# Pick ONE of the variants below and uncomment it.
[embedding]

# Self-hosted multimodal embedding (qwen3-vl-embedding)
#enabled = true
#provider = "multimodal"
#model = "qwen3-vl-embedding"
#api_key = ""
#api_base = "http://localhost:8070/v1"
#dim = 1024

# SiliconFlow (OpenAI-compatible multimodal embedding)
enabled = true
provider = "siliconflow"
model = "Qwen/Qwen3-VL-Embedding-8B"
api_key = ""                                  # e.g. "sk-..." (your own key)
api_base = "https://api.siliconflow.cn/v1"
dim = 1024

# ==============================================================================
# Reranker Settings
# ==============================================================================
[reranker]
enabled = false
mode = "api"
url = "http://localhost:8083/rerank"
model = "Qwen/Qwen3-Reranker-0.6B"
api_key = ""

# ==============================================================================
# Processing Settings
# ==============================================================================
[processing]
mode = "ocr"
queue_capacity = 500
preload_models = true

# ==============================================================================
# UI Settings
# ==============================================================================
[ui]
show_ai_description = true

# ==============================================================================
# Advanced Settings
# ==============================================================================
[advanced]
fusion_log_enabled = false
