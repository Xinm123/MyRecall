# OpenRecall Client Configuration Template
# Copy this file to myrecall_client.env and fill in your values

# ==============================================================================
# Connection Settings
# ==============================================================================
# The URL of the OpenRecall server API
OPENRECALL_API_URL=http://localhost:8083/api

# Upload timeout in seconds (increase if server is slow processing)
OPENRECALL_UPLOAD_TIMEOUT=180

# ==============================================================================
# Capture Settings
# ==============================================================================
# Screenshot capture interval in seconds
OPENRECALL_CAPTURE_INTERVAL=30

# Minimum debounce interval between captures (ms)
OPENRECALL_MIN_CAPTURE_INTERVAL_MS=3000

# Idle fallback interval (ms)
OPENRECALL_IDLE_CAPTURE_INTERVAL_MS=60000

# Only capture the primary monitor (set to false to capture all monitors)
OPENRECALL_PRIMARY_MONITOR_ONLY=false

# Disable similarity-based deduplication
OPENRECALL_DISABLE_SIMILARITY_FILTER=false

# Similarity threshold (0.0-1.0)
OPENRECALL_SIMILARITY_THRESHOLD=0.9

# ==============================================================================
# P1-S2b+ Simhash Dedup Configuration
# ==============================================================================
# Enable PHash-based similarity deduplication
OPENRECALL_SIMHASH_DEDUP_ENABLED=true

# Hamming distance threshold for similarity
OPENRECALL_SIMHASH_DEDUP_THRESHOLD=8

# Number of recent hashes cached per monitor/device
OPENRECALL_SIMHASH_CACHE_SIZE=1

# Per-trigger-type simhash enablement
OPENRECALL_SIMHASH_ENABLED_FOR_CLICK=true
OPENRECALL_SIMHASH_ENABLED_FOR_APP_SWITCH=true

# ==============================================================================
# Debug & Storage
# ==============================================================================
# Enable debug logging
OPENRECALL_DEBUG=true

# Save screenshots locally on the client (useful for debugging)
# OPENRECALL_CLIENT_SAVE_LOCAL_SCREENSHOTS=false

# ==============================================================================
# Distributed Mode (Client and Edge on different machines)
# ==============================================================================
# By default, OPENRECALL_API_URL points to localhost:8083 (same-machine mode).
# For distributed mode, set it to the Edge machine's address:
#
#   OPENRECALL_API_URL=http://192.168.1.100:8083/api
#
# EDGE_BASE_URL is auto-derived from OPENRECALL_API_URL (removes /api suffix),
# so you only need to configure OPENRECALL_API_URL.
#
# The browser accesses the Client web UI at http://<this-machine-ip>:8883
# and the JS automatically uses OPENRECALL_API_URL's host as the Edge API target.
#
# Both machines must be on the same network (LAN or VPN).

# ==============================================================================
# Chat LLM Settings (for distributed mode: use local vLLM on server)
# ==============================================================================
# When using the "Custom (Self-hosted)" provider for Chat:
# Set the custom API base URL (pointing to the server machine's LLM service)
# OPENRECALL_CHAT_API_BASE=http://192.168.1.100:8080/v1
